# ─────────────────────────────────────────────────────────────────────────────
# LBD-SIP Intelligence Platform — Environment Variables
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to git. All production secrets MUST be stored in
# Supabase Vault (Dashboard → Vault) or your CI/CD secrets manager.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────

# Your Supabase project URL (found in Project Settings → API)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase anon/publishable key — safe to expose in frontend
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Project reference ID (used by Supabase CLI)
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# ── AI / Edge Function secrets (store in Supabase Vault in production) ────────
# These are accessed server-side by Supabase Edge Functions via Deno.env.get()
# They should NEVER appear in VITE_ prefixed vars (those are bundled into client)

# OpenAI API key — used by ai-summarise, check-narrative-compliance functions
# Supabase Vault key name: OPENAI_API_KEY
# OPENAI_API_KEY="sk-..."

# Twitter/X Bearer Token — used by sync-twitter, sync-twitter-competitors
# Supabase Vault key name: TWITTER_BEARER_TOKEN
# TWITTER_BEARER_TOKEN="..."

# Meta (Facebook/Instagram) App credentials
# Supabase Vault key name: META_APP_ID, META_APP_SECRET
# META_APP_ID="..."
# META_APP_SECRET="..."

# NewsAPI key — used by sync-news
# Supabase Vault key name: NEWS_API_KEY
# NEWS_API_KEY="..."

# Upstash Redis (for Edge Function rate limiting)
# Supabase Vault key name: UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN
# UPSTASH_REDIS_REST_URL="https://...upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."

# ── Security notes ────────────────────────────────────────────────────────────
# 1. All API keys and secrets must go in Supabase Vault (not .env) in production
# 2. The Supabase service_role key must NEVER be exposed to the frontend
# 3. Enable Supabase RLS on all tables (verified via get_advisors security check)
# 4. MFA is enforced for all internal staff roles (requireMfa: true in ProtectedRoute)
# 5. Session expires after 30min inactivity (enforced in AuthProvider)
# 6. File uploads restricted to: PDF, JPEG, PNG, DOCX, XLSX, MP4 — max 50MB
# 7. CSP headers configured in vite.config.ts (dev) and should be added to
#    hosting platform (Netlify/Vercel) headers config for production
